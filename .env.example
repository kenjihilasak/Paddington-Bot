APP_NAME=Paddington Bot Backend
APP_ENV=development
DEBUG=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/paddington_bot
REDIS_URL=redis://redis:6379/0
USE_FAKE_REDIS=false
AUTO_CREATE_SCHEMA=false
META_VERIFY_TOKEN=replace-this-verify-token
META_ACCESS_TOKEN=replace-this-access-token
META_PHONE_NUMBER_ID=replace-this-phone-number-id
META_GRAPH_VERSION=v21.0
LLM_PROVIDER=openai_compatible
LLM_API_KEY=replace-this-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=15
INTENT_CLASSIFIER_ENABLED=false
INTENT_CLASSIFIER_BASE_URL=http://localhost:8080/v1
INTENT_CLASSIFIER_API_KEY=
INTENT_CLASSIFIER_MODEL=intfloat/multilingual-e5-small
INTENT_CLASSIFIER_TIMEOUT_SECONDS=10
INTENT_CLASSIFIER_THRESHOLD=0.82
CONVERSATION_STATE_TTL_SECONDS=86400
DEFAULT_OFFER_EXPIRY_DAYS=30
DEFAULT_LISTING_EXPIRY_DAYS=30
DEFAULT_SUMMARY_LIMIT=5
BUSINESS_TIMEZONE=Europe/London

# Example values for running locally without Docker:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/luke_bot
# REDIS_URL=redis://localhost:6379/0
# USE_FAKE_REDIS=true
# AUTO_CREATE_SCHEMA=false
